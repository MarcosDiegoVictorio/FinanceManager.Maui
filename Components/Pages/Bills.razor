@page "/bills"
@inject FinanceService Finance
@inject Services.SessionService Session
@inject NavigationManager Nav
@inject ApiService ApiService
@using System.Globalization
@using System.ComponentModel.DataAnnotations
@using FinanceManager.Maui.Models

<div class="finance-app">
    <header class="app-header">
        <h1>FinanceVictorios</h1>
        <p class="subtitle">Contas a Pagar e Alertas 💸</p>
    </header>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="error-banner card animate-slide-up">
            <span class="error-text">⚠️ @_errorMessage</span>
            <button type="button" class="btn-retry" @onclick="ReloadAsync">Tentar Novamente</button>
        </div>
    }

    <section class="form-card card">
        <h3>Nova Conta a Pagar</h3>
        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <div class="success-banner animate-fade-in">
                ✨ @_successMessage
            </div>
        }
        <EditForm Model="_form" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />
            <div class="form-grid">
                <div class="field full">
                    <label>Descrição</label>
                    <InputText @bind-Value="_form.Description" class="input" placeholder="Ex: Cartão de Crédito, Energia, Internet..." />
                    <ValidationMessage For="@(() => _form.Description)" class="validation-message" style="color: #ef4444; font-size: 0.8rem; margin-top: 0.25rem; display: block;" />
                </div>
                <div class="field">
                    <label>Valor (R$)</label>
                    <InputNumber @bind-Value="_form.Value" class="input" placeholder="0,00" />
                    <ValidationMessage For="@(() => _form.Value)" class="validation-message" style="color: #ef4444; font-size: 0.8rem; margin-top: 0.25rem; display: block;" />
                </div>
                <div class="field">
                    <label>Data de Vencimento</label>
                    <InputDate @bind-Value="_form.DueDate" class="input" />
                    <ValidationMessage For="@(() => _form.DueDate)" class="validation-message" style="color: #ef4444; font-size: 0.8rem; margin-top: 0.25rem; display: block;" />
                </div>
                <div class="field">
                    <label>Dias antes para notificar</label>
                    <input type="number" @bind="_form.DaysBeforeToNotify" class="input" min="0" max="365" />
                    <ValidationMessage For="@(() => _form.DaysBeforeToNotify)" class="validation-message" style="color: #ef4444; font-size: 0.8rem; margin-top: 0.25rem; display: block;" />
                </div>
                <div class="field">
                    <label>Total de Parcelas</label>
                    <InputNumber @bind-Value="_form.TotalInstallments" class="input" min="1" max="48" />
                    <ValidationMessage For="@(() => _form.TotalInstallments)" class="validation-message" style="color: #ef4444; font-size: 0.8rem; margin-top: 0.25rem; display: block;" />
                </div>
            </div>
            <button type="submit" class="btn-primary" disabled="@_saving">
                @(_saving ? "Salvando..." : "Agendar Conta")
            </button>
        </EditForm>
    </section>

    <section class="list-card card">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
            <h3 style="margin: 0;">Minhas Contas Agendadas</h3>
            <div style="display: flex; gap: 0.5rem; align-items: center;">
                <select @bind="_statusFilter" @bind:after="ReloadAsync" class="input" style="width: auto; max-width: 140px; margin: 0; padding: 0.35rem 0.65rem; font-size: 0.85rem; background: var(--surface-2); border: 1px solid rgba(255,255,255,0.08); color: var(--text);">
                    <option value="">Todos Status</option>
                    <option value="pendente">Pendentes</option>
                    <option value="pago">Pagas</option>
                </select>
                <select @bind="_monthFilter" @bind:after="ReloadAsync" class="input" style="width: auto; max-width: 130px; margin: 0; padding: 0.35rem 0.65rem; font-size: 0.85rem; background: var(--surface-2); border: 1px solid rgba(255,255,255,0.08); color: var(--text);">
                    <option value="">Todos Meses</option>
                    <option value="1">Janeiro</option>
                    <option value="2">Fevereiro</option>
                    <option value="3">Março</option>
                    <option value="4">Abril</option>
                    <option value="5">Maio</option>
                    <option value="6">Junho</option>
                    <option value="7">Julho</option>
                    <option value="8">Agosto</option>
                    <option value="9">Setembro</option>
                    <option value="10">Outubro</option>
                    <option value="11">Novembro</option>
                    <option value="12">Dezembro</option>
                </select>
            </div>
        </div>

        @if (_isLoading)
        {
            <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1rem;">
                <div class="skeleton" style="width: 100%; height: 55px; border-radius: 8px;"></div>
                <div class="skeleton" style="width: 100%; height: 55px; border-radius: 8px;"></div>
            </div>
        }
        else if (_bills.Count == 0)
        {
            <p class="empty">Nenhuma conta cadastrada.</p>
        }
        else
        {
            <ul class="transaction-list">
                @foreach (var item in _bills)
                {
                    <li class="transaction-item animate-fade-in">
                        <div class="tx-main">
                            <strong style="@(item.IsPaid ? "text-decoration: line-through; opacity: 0.6;" : "")">@item.Description</strong>
                            <span class="tx-category">
                                @if (item.IsPaid)
                                {
                                    <span style="color: #4ade80; font-weight: bold;">✓ Paga</span>
                                    if (item.PaymentDate.HasValue)
                                    {
                                        <span> em: @item.PaymentDate.Value.ToLocalTime().ToString("dd/MM/yyyy")</span>
                                    }
                                }
                                else
                                {
                                    <span>Vence em: @item.DueDate.ToString("dd/MM/yyyy")</span>
                                }
                            </span>
                        </div>
                        <div class="tx-meta">
                            <span class="tx-value negative" style="@(item.IsPaid ? "opacity: 0.6;" : "")">
                                @item.Value.ToString("C", PtBr)
                            </span>
                            @if (item.DaysBeforeToNotify == 0)
                            {
                                <span class="badge fixed" style="background: rgba(239, 68, 68, 0.2); color: var(--danger);">No dia</span>
                            }
                            else
                            {
                                <span class="badge installment">Aviso: @item.DaysBeforeToNotify @(item.DaysBeforeToNotify == 1 ? "dia" : "dias") antes</span>
                            }
                        </div>
                        <div style="display: flex; gap: 0.5rem; align-items: center;">
                            @if (!item.IsPaid)
                            {
                                <button type="button" class="btn-pay" @onclick="() => PayAsync(item.Id)" title="Marcar como Paga">Pagar ✓</button>
                            }
                            <button type="button" class="btn-delete" @onclick="() => DeleteAsync(item.Id)" title="Excluir">×</button>
                        </div>
                    </li>
                }
            </ul>
        }
    </section>
</div>

<style>
    .negative {
        color: #ef4444 !important;
    }

    /* Skeleton Loader CSS */
    .skeleton {
        background: linear-gradient(90deg, #1e293b 25%, #334155 50%, #1e293b 75%);
        background-size: 200% 100%;
        animation: loading-pulse 1.5s infinite ease-in-out;
        border-radius: 6px;
        display: inline-block;
    }

    @@keyframes loading-pulse {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    /* Error Banner CSS */
    .error-banner {
        background: linear-gradient(135deg, #7f1d1d 0%, #991b1b 100%);
        border: 1px solid rgba(239, 68, 68, 0.3) !important;
        padding: 0.75rem 1.25rem !important;
        margin-bottom: 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .error-text {
        color: #fee2e2;
        font-size: 0.85rem;
        font-weight: 500;
    }

    .btn-pay {
        background: rgba(34, 197, 94, 0.12);
        color: #4ade80;
        border: 1px solid rgba(34, 197, 94, 0.25);
        padding: 0.3rem 0.65rem;
        font-size: 0.75rem;
        font-weight: 700;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-pay:hover {
        background: #22c55e;
        color: #0f1419;
        border-color: #22c55e;
    }

    .btn-retry {
        background: rgba(255, 255, 255, 0.15);
        color: #ffffff;
        border: none;
        padding: 0.35rem 0.75rem;
        font-size: 0.75rem;
        font-weight: 700;
        border-radius: 6px;
        cursor: pointer;
        transition: background 0.2s;
    }

    .btn-retry:hover {
        background: rgba(255, 255, 255, 0.25);
    }

    /* Success Banner CSS */
    .success-banner {
        background: linear-gradient(135deg, #065f46 0%, #047857 100%);
        border: 1px solid rgba(52, 211, 153, 0.3);
        color: #ecfdf5;
        padding: 0.75rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
        font-size: 0.85rem;
        font-weight: 600;
        text-align: center;
        box-shadow: 0 4px 12px rgba(4, 120, 87, 0.2);
    }
</style>

@code {
    private static readonly CultureInfo PtBr = CultureInfo.GetCultureInfo("pt-BR");
    private List<BillToPay> _bills = [];
    private readonly BillForm _form = new();
    private bool _saving;
    
    private bool _isLoading;
    private string? _errorMessage;
    private string? _successMessage;

    private string _statusFilter = string.Empty;
    private string _monthFilter = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (Session.CurrentUser is null)
        {
            Nav.NavigateTo("login");
            return;
        }

        await RequestNotificationsPermissionAsync();
        await ReloadAsync();
    }

    private async Task RequestNotificationsPermissionAsync()
    {
#if ANDROID || IOS
        try
        {
            if (await Plugin.LocalNotification.LocalNotificationCenter.Current.AreNotificationsEnabled() == false)
            {
                await Plugin.LocalNotification.LocalNotificationCenter.Current.RequestNotificationPermission();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao solicitar permissão de notificações: {ex.Message}");
        }
#else
        await Task.CompletedTask;
#endif
    }

    private async Task ReloadAsync()
    {
        if (Session.CurrentUser is null) return;
        
        _isLoading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            int? filterMonth = null;
            if (int.TryParse(_monthFilter, out var parsedMonth))
            {
                filterMonth = parsedMonth;
            }

            _bills = await ApiService.GetBillsAsync(
                string.IsNullOrEmpty(_statusFilter) ? null : _statusFilter, 
                filterMonth
            );
        }
        catch (Exception ex)
        {
            _errorMessage = "Não foi possível carregar suas contas agendadas. Tente novamente.";
            Console.WriteLine($"Erro ao carregar contas: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SaveAsync()
    {
        if (Session.CurrentUser is null) return;
        if (string.IsNullOrWhiteSpace(_form.Description) || !_form.Value.HasValue || _form.Value.Value <= 0)
            return;

        _saving = true;
        _errorMessage = null;
        try
        {
            await ApiService.CreateBillAsync(new BillDto
            {
                Description = _form.Description.Trim(),
                Value = _form.Value.Value,
                DueDate = _form.DueDate,
                DaysBeforeToNotify = _form.DaysBeforeToNotify,
                TotalInstallments = _form.TotalInstallments
            });

            _form.Reset();
            _successMessage = "Conta agendada com sucesso!";
            StateHasChanged();
            
            await ReloadAsync();
            
            // Success banner vanishes after 3 seconds
            _ = Task.Delay(3000).ContinueWith(_ => 
            {
                _successMessage = null;
                InvokeAsync(StateHasChanged);
            });
        }
        catch (Exception ex)
        {
            _errorMessage = "Erro ao tentar agendar a conta. Tente novamente.";
            Console.WriteLine($"Erro ao salvar conta: {ex.Message}");
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task PayAsync(int id)
    {
        if (Session.CurrentUser is null) return;
        _errorMessage = null;
        try
        {
            await ApiService.MarkAsPaidAsync(id);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = "Erro ao marcar conta como paga. Tente novamente.";
            Console.WriteLine($"Erro ao pagar conta: {ex.Message}");
        }
    }

    private async Task DeleteAsync(int id)
    {
        if (Session.CurrentUser is null) return;
        _errorMessage = null;
        try
        {
            await ApiService.DeleteBillAsync(id);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = "Erro ao excluir conta. Tente novamente.";
            Console.WriteLine($"Erro ao deletar conta: {ex.Message}");
        }
    }

    private sealed class BillForm
    {
        [Required(ErrorMessage = "A descrição é obrigatória.")]
        public string Description { get; set; } = string.Empty;

        [Required(ErrorMessage = "O valor é obrigatório.")]
        [Range(0.01, double.MaxValue, ErrorMessage = "O valor deve ser maior que zero.")]
        public decimal? Value { get; set; }

        [Required(ErrorMessage = "A data de vencimento é obrigatória.")]
        public DateTime DueDate { get; set; } = DateTime.Today;

        [Range(0, 365, ErrorMessage = "O número de dias deve ser entre 0 e 365.")]
        public int DaysBeforeToNotify { get; set; } = 1;

        [Range(1, 48, ErrorMessage = "O número de parcelas deve ser entre 1 e 48.")]
        public int TotalInstallments { get; set; } = 1;

        public void Reset()
        {
            Description = string.Empty;
            Value = null;
            DueDate = DateTime.Today;
            DaysBeforeToNotify = 1;
            TotalInstallments = 1;
        }
    }
}
