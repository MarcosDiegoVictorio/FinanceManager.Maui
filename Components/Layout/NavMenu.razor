@inject Services.SessionService Session
@inject NavigationManager Nav

<header class="top-navbar">
    <div class="navbar-left">
        <button type="button" class="menu-toggle-btn" @onclick="OpenDrawer" aria-label="Abrir Menu">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="4" y1="12" x2="20" y2="12" />
                <line x1="4" y1="6" x2="20" y2="6" />
                <line x1="4" y1="18" x2="20" y2="18" />
            </svg>
        </button>
        <a class="brand-link" href="" @onclick="CloseDrawer">
            <span class="brand-icon">💎</span>
            <span class="brand-text">FinanceVictorios</span>
        </a>
    </div>
    
    <div class="navbar-right">
        @if (Session.CurrentUser != null)
        {
            <span class="user-greeting">Olá, @Session.CurrentUser.Name</span>
        }
    </div>
</header>

<!-- Backdrop Overlay -->
<div class="drawer-backdrop @(_isOpen ? "active" : "")" @onclick="CloseDrawer"></div>

<!-- Slide-out Drawer -->
<aside class="sidebar-drawer @(_isOpen ? "open" : "")">
    <div class="drawer-header">
        <div class="brand-section">
            <span class="brand-icon">💎</span>
            <span class="brand-text">FinanceVictorios</span>
        </div>
        <button type="button" class="drawer-close-btn" @onclick="CloseDrawer" aria-label="Fechar Menu">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
        </button>
    </div>

    <nav class="drawer-menu">
        <div class="nav-item">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All" @onclick="CloseDrawer" title="Dashboard">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="9" rx="1" />
                        <rect x="14" y="3" width="7" height="5" rx="1" />
                        <rect x="14" y="12" width="7" height="9" rx="1" />
                        <rect x="3" y="16" width="7" height="5" rx="1" />
                    </svg>
                </span>
                <span class="nav-text">Dashboard</span>
            </NavLink>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="main" @onclick="CloseDrawer" title="Lançamento">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="8" x2="12" y2="16" />
                        <line x1="8" y1="12" x2="16" y2="12" />
                    </svg>
                </span>
                <span class="nav-text">Lançamento</span>
            </NavLink>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="categories" @onclick="CloseDrawer" title="Categorias">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="7" rx="1" />
                        <rect x="14" y="3" width="7" height="7" rx="1" />
                        <rect x="14" y="14" width="7" height="7" rx="1" />
                        <rect x="3" y="14" width="7" height="7" rx="1" />
                    </svg>
                </span>
                <span class="nav-text">Categorias</span>
            </NavLink>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="bills" @onclick="CloseDrawer" title="Contas a Pagar">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                        <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                    </svg>
                </span>
                <span class="nav-text">Contas a Pagar</span>
            </NavLink>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="group" @onclick="CloseDrawer" title="Grupo">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                        <path d="M21 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M9 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                    </svg>
                </span>
                <span class="nav-text">Grupo</span>
            </NavLink>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="premium-upgrade" @onclick="CloseDrawer" title="Premium Upgrade">
                <span class="nav-icon" style="@(Session.CurrentUser?.IsPremium == true ? "color: #fbbf24;" : "")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="8" r="7" />
                        <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88" />
                    </svg>
                </span>
                <span class="nav-text" style="@(Session.CurrentUser?.IsPremium == true ? "font-weight: bold; color: #fbbf24;" : "")">
                    @(Session.CurrentUser?.IsPremium == true ? "Premium 👑" : "Seja Premium ⭐")
                </span>
            </NavLink>
        </div>

        <!-- Sair (Logout) -->
        <div class="nav-item nav-logout">
            <button type="button" class="nav-link btn-logout" @onclick="Logout" title="Sair (@Session.CurrentUser?.Name)">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                </span>
                <span class="nav-text">Sair (@Session.CurrentUser?.Name)</span>
            </button>
        </div>
    </nav>
</aside>

@code {
    private bool _isOpen;

    private void OpenDrawer()
    {
        _isOpen = true;
    }

    private void CloseDrawer()
    {
        _isOpen = false;
    }

    private void Logout()
    {
        CloseDrawer();
        Session.ClearSession();
        Nav.NavigateTo("login");
    }
}
